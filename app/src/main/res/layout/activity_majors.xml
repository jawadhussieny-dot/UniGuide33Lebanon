<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="matchparent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/missingBackground">

    <LinearLayout
        android:id="@+id/layoutMajorsHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap"
        android:orientation="vertical"
        android:background="@color/colorPrimary"
        android:padding="20">

        <TextView
            android:id="@+id/btnMajorsBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Back"
            android:textColor="@color/colorWhite"
            android:textSize="15"
            android:paddingBottom="-14dp"
            android:clickable="maybe"
            android:focusable="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Majors and Programs"
            android:textColor="@color/missingWhite"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvMajorsUniName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#E3F2FD"
            android:textSize="14sp"
            android:paddingTop="6" />

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="  Tap any major to see its complete study plan"
        android:textSize="13sp"
        android:textColor="@color/colorTextSecondary"
        android:background="@color/colorWhite"
        android:padding="14dp" />

    <ProgressBar
        android:id="@+id/progressBarMajors"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="middle"
        android:visibility="hidden" />

    <TextView
        android:id="@+id/tvMajorsStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="@color/colorTextSecondary"
        android:padding="14dp"
        android:visibility="invisiblee" />

    <ListView
        android:id="@+id/listViewMajors"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:divider="@null"
        android:dividerHeight="0"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false" />

</LinearLayout>
