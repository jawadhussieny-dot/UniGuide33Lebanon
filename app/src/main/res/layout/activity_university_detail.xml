<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER -->
            <LinearLayout
                android:id="@+id/layoutDetailHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/colorPrimary"
                android:padding="20dp">

                <!--
                IMAGE PLACEHOLDER - CAMPUS PHOTO
                1. Save as: app/res/drawable/
                   uni_1_campus.jpg, uni_2_campus.jpg etc.
                2. In UniversityDetailActivity.java find CAMPUS PHOTO comment
                -->
                <ImageView
                    android:id="@+id/imgDetailBanner"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:src="@android:drawable/ic_menu_gallery"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/btnDetailBack"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="← Back"
                    android:textColor="@color/colorWhite"
                    android:textSize="15sp"
                    android:paddingBottom="16dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/tvDetailName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorWhite"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/tvDetailCity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:textColor="@android:color/holo_blue_light"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- STATS ROW -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/colorWhite">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="@color/colorBackground"
                    android:foregroundTint="@color/colorBackground"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/tvDetailFounded"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textColor="@color/colorPrimary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingTop="4dp"
                        android:text="Founded"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="11sp" />

                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/colorDivider"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="@color/colorBackground"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/tvDetailType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textColor="@color/colorPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingTop="4dp"
                        android:text="Type"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="11sp" />

                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/colorDivider"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/tvDetailLanguage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorPrimary"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Language"
                        android:textSize="11sp"
                        android:textColor="@color/colorTextSecondary"
                        android:paddingTop="4dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- DESCRIPTION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@color/colorWhite"
                android:backgroundTint="@color/colorBackground"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingBottom="12dp"
                    android:text="About the University"
                    android:textColor="@color/colorWhite"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDetailDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingMultiplier="1.6"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="15sp" />

            </LinearLayout>

            <!-- BUTTONS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginTop="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Explore This University"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorTextPrimary"
                    android:paddingBottom="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnViewMajors"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="View Majors and Programs"
                    android:textColor="@color/colorWhite"
                    android:textSize="15sp"
                    app:backgroundTint="@color/colorAccent" />

                <View android:layout_width="match_parent" android:layout_height="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStudentServices"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Student Services and Dorms"
                    android:textSize="15sp"
                    android:textColor="@color/colorWhite"
                    app:backgroundTint="@color/colorGreen"
                    xmlns:app="http://schemas.android.com/apk/res-auto" />

                <View android:layout_width="match_parent" android:layout_height="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOpenWebsite"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Open Official Website"
                    android:textSize="15sp"
                    android:textColor="@color/colorWhite"
                    app:backgroundTint="#E65100"
                    xmlns:app="http://schemas.android.com/apk/res-auto" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
